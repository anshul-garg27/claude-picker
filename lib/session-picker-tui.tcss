/* ──────────────────────────────────────────────────────────────────
   claude-picker TUI — Catppuccin Mocha theme
   Two-pane session picker, modelled on the website mockup.
   ────────────────────────────────────────────────────────────────── */

Screen {
    background: #1E1E2E;
    color: #CDD6F4;
}

/* The whole app is a vertical column: title, two-pane, footer. */
#root {
    layout: vertical;
    height: 100%;
    padding: 1 2 0 2;
}

/* Title bar (top rule + "claude-picker" + mode marker) */
#title-bar {
    height: 1;
    padding: 0 1;
    color: #6C7086;
    background: #1E1E2E;
}

#title-bar Label {
    color: #6C7086;
}

#title-bar #title-name {
    color: #CBA6F7;
    text-style: bold;
}

#title-bar #title-mode {
    color: #A6ADC8;
    text-align: right;
}

/* Main two-pane area */
#main {
    layout: horizontal;
    height: 1fr;
    padding: 1 0 0 0;
}

#list-pane {
    layout: vertical;
    width: 55%;
    height: 100%;
    border: round #45475A;
    background: #1E1E2E;
    padding: 0 1;
    margin-right: 1;
}

#list-pane:focus-within {
    border: round #6C7086;
}

#preview-pane {
    layout: vertical;
    width: 45%;
    height: 100%;
    border: round #45475A;
    background: #181825;
    padding: 1 2;
}

/* Filter input — sits at the top of the left pane */
#filter {
    height: 3;
    background: #181825;
    border: round #313244;
    color: #CDD6F4;
    padding: 0 1;
    margin: 0 0 1 0;
}

#filter:focus {
    border: round #CBA6F7;
    background: #11111B;
}

#filter > .input--placeholder {
    color: #585B70;
    text-style: italic;
}

#filter > .input--cursor {
    background: #CBA6F7;
    color: #1E1E2E;
}

#filter > .input--cursor-blink {
    background: #CBA6F7;
    color: #1E1E2E;
}

/* Counter row: "N / M" right-aligned above the list */
#counter-row {
    height: 1;
    layout: horizontal;
}

#counter-left {
    width: 1fr;
    color: #6C7086;
    text-style: italic;
}

#counter-right {
    width: auto;
    color: #A6ADC8;
    text-align: right;
    text-style: bold;
}

/* The session list. DataTable customised to feel like a row picker. */
#sessions {
    height: 1fr;
    background: transparent;
    color: #CDD6F4;
    border: none;
    scrollbar-size: 1 1;
    scrollbar-background: #1E1E2E;
    scrollbar-color: #313244;
    scrollbar-color-hover: #45475A;
    scrollbar-color-active: #CBA6F7;
}

#sessions > .datatable--header {
    background: #1E1E2E;
    color: #6C7086;
    text-style: italic;
}

#sessions > .datatable--cursor {
    background: #313244;
    color: #A6E3A1;
    text-style: bold;
}

#sessions > .datatable--hover {
    background: #11111B;
}

#sessions > .datatable--even-row {
    background: transparent;
}

#sessions > .datatable--odd-row {
    background: transparent;
}

/* Empty state (shown when no sessions matched the filter) */
#empty {
    height: 1fr;
    content-align: center middle;
    color: #6C7086;
    text-style: italic;
    display: none;
}

#empty.-visible {
    display: block;
}

/* When empty is visible we hide the table; toggled from Python. */
#sessions.-hidden {
    display: none;
}

/* ── Preview pane ── */

#preview-header {
    layout: horizontal;
    height: 1;
    margin-bottom: 1;
}

#preview-label {
    color: #6C7086;
    text-style: bold;
    width: 1fr;
}

#preview-id {
    color: #A6ADC8;
    width: auto;
    text-align: right;
}

#preview-title {
    color: #A6E3A1;
    text-style: bold;
    height: 1;
    margin-bottom: 1;
}

#preview-meta {
    color: #585B70;
    height: 1;
    margin-bottom: 1;
}

#preview-divider {
    color: #313244;
    height: 1;
    margin-bottom: 1;
}

#preview-content {
    height: 1fr;
    color: #CDD6F4;
    background: transparent;
    padding: 0;
    overflow-y: auto;
    scrollbar-size: 1 1;
    scrollbar-background: #181825;
    scrollbar-color: #313244;
    scrollbar-color-hover: #45475A;
}

#preview-stats {
    dock: bottom;
    height: 2;
    color: #6C7086;
    border-top: solid #313244;
    padding: 1 0 0 0;
    text-align: left;
}

/* Toast overlay — "coming soon in v2" for unimplemented actions */
#toast {
    dock: bottom;
    layer: overlay;
    offset: 0 -4;
    width: 40;
    height: 3;
    background: #313244;
    border: round #CBA6F7;
    color: #CDD6F4;
    content-align: center middle;
    display: none;
    text-style: bold;
}

#toast.-visible {
    display: block;
}

/* Built-in Footer — Textual 8.x uses FooterKey component classes. */
Footer {
    background: #11111B;
    color: #A6ADC8;
    height: 1;
}

FooterKey {
    background: #11111B;
    color: #A6ADC8;
}

FooterKey > .footer-key--key {
    background: #313244;
    color: #F9E2AF;
    text-style: bold;
}

FooterKey > .footer-key--description {
    background: #11111B;
    color: #A6ADC8;
}

FooterKey.-hovered {
    background: #45475A;
    color: #A6E3A1;
}

FooterKey.-hovered > .footer-key--key {
    background: #45475A;
    color: #F9E2AF;
    text-style: bold;
}

/* Subtle fade-in for pane content when selection changes. */
#preview-content {
    transition: opacity 250ms in_out_cubic;
}
