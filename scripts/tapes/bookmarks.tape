# bookmarks.tape — Ctrl+B to pin a session
# Run: cd ~/Desktop/claude-picker && vhs scripts/tapes/bookmarks.tape

Output assets/gifs/bookmarks.gif
Output assets/videos/bookmarks.webm

Set Shell bash
Set FontSize 16
Set Width 1400
Set Height 800
Set Theme "Catppuccin Mocha"
Set Padding 30
Set TypingSpeed 50ms
Set CursorBlink false

Hide
Type "alias claude-picker='bash ./scripts/demo-mode.sh' ; clear"
Enter
Show

Sleep 500ms
Type "claude-picker"
Sleep 600ms
Enter
Sleep 2000ms

Enter
Sleep 2000ms

Down
Sleep 300ms
Down
Sleep 300ms
Down
Sleep 1000ms

Ctrl+B
Sleep 2000ms

Up
Sleep 500ms
Up
Sleep 500ms
Up
Sleep 500ms
Up
Sleep 1500ms

Escape
Sleep 1500ms
