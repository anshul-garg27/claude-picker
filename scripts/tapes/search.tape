# search.tape — claude-picker --search full-text across projects
# Run: cd ~/Desktop/claude-picker && vhs scripts/tapes/search.tape

Output assets/gifs/search.gif
Output assets/videos/search.webm

Set Shell bash
Set FontSize 16
Set Width 1400
Set Height 800
Set Theme "Catppuccin Mocha"
Set Padding 30
Set TypingSpeed 50ms
Set CursorBlink false

Hide
Type "alias claude-picker='bash ./scripts/demo-mode-search.sh' ; clear"
Enter
Show

Sleep 500ms
Type "claude-picker --search"
Sleep 600ms
Enter
Sleep 2500ms

Down
Sleep 700ms
Down
Sleep 700ms
Down
Sleep 1200ms
Up
Sleep 400ms
Up
Sleep 400ms
Up
Sleep 1000ms

Enter
Sleep 2000ms
