# export.tape — Ctrl+E to export a session to markdown
# Run: cd ~/Desktop/claude-picker && vhs scripts/tapes/export.tape

Output assets/gifs/export.gif
Output assets/videos/export.webm

Set Shell bash
Set FontSize 16
Set Width 1400
Set Height 800
Set Theme "Catppuccin Mocha"
Set Padding 30
Set TypingSpeed 50ms
Set CursorBlink false

Hide
Type "alias claude-picker='bash ./scripts/demo-mode.sh' ; clear"
Enter
Show

Sleep 500ms
Type "claude-picker"
Sleep 600ms
Enter
Sleep 2000ms

Enter
Sleep 2000ms

Down
Sleep 300ms
Down
Sleep 300ms
Down
Sleep 1200ms

Ctrl+E
Sleep 2500ms

Enter
Sleep 2000ms
