#!/bin/bash
# claude-picker — Find, preview, and resume your Claude Code sessions
# https://github.com/anshul-garg27/claude-picker

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CLAUDE_FLAGS="${CLAUDE_PICKER_FLAGS:---dangerously-skip-permissions}"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Stats mode: claude-picker --stats
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

if [ "$1" = "--stats" ]; then
  python3 "$SCRIPT_DIR/lib/session-stats.py"
  exit 0
fi

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Tree mode: claude-picker --tree
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

if [ "$1" = "--tree" ] || [ "$1" = "-t" ]; then
  python3 "$SCRIPT_DIR/lib/session-tree.py"
  exit 0
fi

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Diff mode: claude-picker --diff
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

if [ "$1" = "--diff" ] || [ "$1" = "-d" ]; then
  # Collect all sessions across all projects for picking
  all_sessions=$(python3 -c "
import json, glob, os, time
from datetime import datetime

projects_dir = os.path.expanduser('~/.claude/projects')
sessions_dir = os.path.expanduser('~/.claude/sessions')
now = time.time()

R  = '\033[0m';  B  = '\033[1m';  D  = '\033[2m';  I  = '\033[3m'
CY = '\033[38;5;117m'; GN = '\033[38;5;114m'; YL = '\033[38;5;222m'
MG = '\033[38;5;176m'; DG = '\033[38;5;242m'; GR = '\033[38;5;249m'

def relative_time(ts):
    diff = now - ts
    if diff < 60: return 'just now'
    elif diff < 3600: return f'{int(diff/60)}m ago'
    elif diff < 86400: return f'{int(diff/3600)}h ago'
    elif diff < 604800: return f'{int(diff/86400)}d ago'
    else: return datetime.fromtimestamp(ts).strftime('%b %d')

meta_by_sid = {}
for mf in glob.glob(os.path.join(sessions_dir, '*.json')):
    try:
        data = json.load(open(mf))
        sid = data.get('sessionId', '')
        if sid: meta_by_sid[sid] = data
    except: pass

noise = ['<local-command', '<command-name>', '<bash-', '<system-reminder>', '[Request inter', '---', '<command-message>']

for proj_dir_name in sorted(os.listdir(projects_dir)):
    full_proj = os.path.join(projects_dir, proj_dir_name)
    if not os.path.isdir(full_proj): continue

    proj_name = None
    for sid_key, meta in meta_by_sid.items():
        cwd = meta.get('cwd', '')
        if cwd and cwd.replace('/', '-').replace('_', '-') == proj_dir_name:
            proj_name = os.path.basename(cwd); break
    if not proj_name:
        proj_name = proj_dir_name.split('-')[-1][:20]

    for jf in sorted(glob.glob(os.path.join(full_proj, '*.jsonl')), key=os.path.getmtime, reverse=True):
        session_id = os.path.basename(jf).replace('.jsonl', '')
        mod_ts = os.path.getmtime(jf)
        rel = relative_time(mod_ts)

        is_claude = True
        try:
            for line in open(jf):
                data = json.loads(line.strip())
                ep = data.get('entrypoint', '')
                if ep and ep not in ('cli', 'sdk-cli'):
                    is_claude = False; break
                if ep in ('cli', 'sdk-cli'): break
        except: pass
        if not is_claude: continue

        name = None; auto_name = None; msg_count = 0
        try:
            for line in open(jf):
                data = json.loads(line.strip())
                if data.get('type') == 'custom-title' and data.get('customTitle'):
                    name = data['customTitle'][:35]
                if data.get('type') in ('user', 'assistant') and data.get('message', {}).get('role') in ('user', 'assistant'):
                    msg_count += 1
                    if not auto_name and data.get('type') == 'user':
                        content = data['message'].get('content', '')
                        text = ''
                        if isinstance(content, str): text = content.strip()
                        elif isinstance(content, list):
                            for item in content:
                                if isinstance(item, dict) and item.get('type') == 'text':
                                    text = item['text'].strip(); break
                        if text and len(text) > 3 and not any(n in text for n in noise):
                            auto_name = text[:50].replace(chr(10), ' ').strip()
        except: pass

        if not name:
            meta = meta_by_sid.get(session_id, {})
            if meta.get('name'): name = meta['name'][:35]

        if msg_count < 2: continue

        display = name or (auto_name[:35] if auto_name else 'session')
        icon = f'{YL}\u25cf' if name else f'{DG}\u25cb'
        nc = GN if name else GR
        ns = B if name else I
        print(f'  {icon}{R}   {ns}{nc}{display:<35s}{R}  {MG}{proj_name:<15s}{R}  {DG}{rel:>9s}{R}  {DG}{msg_count:>3d} msgs{R}  |  {session_id}')
")

  if [ -z "$all_sessions" ]; then
    echo "No sessions found to compare."
    exit 0
  fi

  # Pick first session
  selected_a=$(echo "$all_sessions" | fzf \
    --header=$'  \033[38;5;176m\033[1msession diff\033[0m  \033[38;5;242m│  pick FIRST session to compare\033[0m\n' \
    --header-first \
    --delimiter="|" \
    --with-nth=1 \
    --layout=reverse \
    --height=85% \
    --border=rounded \
    --margin=1,3 \
    --padding=1,1 \
    --prompt="  first > " \
    --pointer=" ▸" \
    --color="fg:249,fg+:114,bg+:-1,hl:222,hl+:222,pointer:176,prompt:114,header:176,border:238,gutter:-1" \
    --no-separator \
    --preview="PROJECT_DIR='' python3 '$SCRIPT_DIR/lib/session-preview.py' \$(echo {} | awk -F'|' '{print \$NF}' | xargs)" \
    --preview-window=right,45%,wrap,border-left \
    --ansi)

  if [ -z "$selected_a" ]; then
    exit 0
  fi
  sid_a=$(echo "$selected_a" | awk -F'|' '{print $NF}' | xargs)

  # Pick second session
  selected_b=$(echo "$all_sessions" | fzf \
    --header=$'  \033[38;5;176m\033[1msession diff\033[0m  \033[38;5;242m│  pick SECOND session to compare\033[0m\n' \
    --header-first \
    --delimiter="|" \
    --with-nth=1 \
    --layout=reverse \
    --height=85% \
    --border=rounded \
    --margin=1,3 \
    --padding=1,1 \
    --prompt="  second > " \
    --pointer=" ▸" \
    --color="fg:249,fg+:222,bg+:-1,hl:222,hl+:222,pointer:176,prompt:222,header:176,border:238,gutter:-1" \
    --no-separator \
    --preview="PROJECT_DIR='' python3 '$SCRIPT_DIR/lib/session-preview.py' \$(echo {} | awk -F'|' '{print \$NF}' | xargs)" \
    --preview-window=right,45%,wrap,border-left \
    --ansi)

  if [ -z "$selected_b" ]; then
    exit 0
  fi
  sid_b=$(echo "$selected_b" | awk -F'|' '{print $NF}' | xargs)

  python3 "$SCRIPT_DIR/lib/session-diff.py" "$sid_a" "$sid_b"
  exit 0
fi

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Pipe mode flag
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

PIPE_MODE=0
if [ "$1" = "--pipe" ] || [ "$1" = "-p" ]; then
  PIPE_MODE=1
  shift
fi

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Search mode: claude-picker --search
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

if [ "$1" = "--search" ] || [ "$1" = "-s" ]; then
  search_results=$(python3 "$SCRIPT_DIR/lib/session-search.py")

  if [ -z "$search_results" ]; then
    echo "No sessions found to search."
    exit 0
  fi

  selected=$(echo "$search_results" | fzf \
    --header=$'  \033[38;5;176m\033[1msearch sessions\033[0m  \033[38;5;242m│  type to filter across all conversations\033[0m\n' \
    --header-first \
    --delimiter="|" \
    --with-nth=1 \
    --layout=reverse \
    --height=85% \
    --border=rounded \
    --margin=1,3 \
    --padding=1,1 \
    --prompt="  search > " \
    --pointer=" ▸" \
    --color="fg:249,fg+:114,bg+:-1,hl:222,hl+:222,pointer:176,prompt:176,header:176,border:238,gutter:-1" \
    --no-separator \
    --preview="PROJECT_DIR='' python3 '$SCRIPT_DIR/lib/session-preview.py' \$(echo {} | awk -F'|' '{print \$NF}' | xargs)" \
    --preview-window=right,45%,wrap,border-left \
    --ansi)

  if [ -n "$selected" ]; then
    session_id=$(echo "$selected" | awk -F'|' '{print $NF}' | xargs)
    claude $CLAUDE_FLAGS --resume "$session_id"
  fi
  exit 0
fi

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Step 1: Pick a project directory
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

dir_list=$(python3 -c "
import os, glob, json, time
from datetime import datetime

projects_dir = os.path.expanduser('~/.claude/projects')
sessions_dir = os.path.expanduser('~/.claude/sessions')
now = time.time()

R  = '\033[0m';  B  = '\033[1m';  D  = '\033[2m'
CY = '\033[38;5;117m'; GN = '\033[38;5;114m'; YL = '\033[38;5;222m'
MG = '\033[38;5;176m'; DG = '\033[38;5;242m'; GR = '\033[38;5;249m'
BL = '\033[38;5;111m'; OR = '\033[38;5;215m'; WH = '\033[97m'

def relative_time(ts):
    diff = now - ts
    if diff < 60: return 'just now'
    elif diff < 3600: return f'{int(diff/60)}m ago'
    elif diff < 86400: return f'{int(diff/3600)}h ago'
    elif diff < 604800: return f'{int(diff/86400)}d ago'
    else: return datetime.fromtimestamp(ts).strftime('%b %d')

meta_cwds = {}
for mf in glob.glob(os.path.join(sessions_dir, '*.json')):
    try:
        data = json.load(open(mf))
        sid = data.get('sessionId', '')
        cwd = data.get('cwd', '')
        if sid and cwd: meta_cwds[sid] = cwd
    except: pass

results = {}

for d in os.listdir(projects_dir):
    full = os.path.join(projects_dir, d)
    if not os.path.isdir(full): continue
    jsonl_files = glob.glob(os.path.join(full, '*.jsonl'))
    if not jsonl_files: continue

    valid_count = 0
    latest_mod = 0
    for jf in jsonl_files:
        is_claude = True
        try:
            for line in open(jf):
                data = json.loads(line.strip())
                ep = data.get('entrypoint', '')
                if ep and ep not in ('cli', 'sdk-cli'):
                    is_claude = False; break
                if ep in ('cli', 'sdk-cli'): break
        except: pass
        if not is_claude: continue
        mod = os.path.getmtime(jf)
        if mod > latest_mod: latest_mod = mod
        msg_count = 0
        try:
            for line in open(jf):
                data = json.loads(line.strip())
                if data.get('type') in ('user', 'assistant') and data.get('message', {}).get('role') in ('user', 'assistant'):
                    msg_count += 1
                    if msg_count >= 2: break
        except: pass
        if msg_count >= 2: valid_count += 1

    if valid_count == 0: continue

    real_path = None
    for jf in jsonl_files:
        try:
            for line in open(jf):
                data = json.loads(line.strip())
                sid = data.get('sessionId', '')
                if sid and sid in meta_cwds:
                    candidate = meta_cwds[sid]
                    if os.path.isdir(candidate): real_path = candidate; break
                break
        except: pass
        if real_path: break
    if not real_path:
        for jf in jsonl_files:
            try:
                for line in open(jf):
                    data = json.loads(line.strip())
                    if 'cwd' in data and data['cwd']:
                        candidate = data['cwd']
                        if os.path.isdir(candidate): real_path = candidate; break
            except: pass
            if real_path: break
    if not real_path:
        for cwd in set(meta_cwds.values()):
            if cwd and cwd.replace('/', '-').replace('_', '-') == d:
                if os.path.isdir(cwd): real_path = cwd; break
    if not real_path: continue

    if real_path not in results:
        results[real_path] = {'count': 0, 'last_mod': 0}
    if valid_count > results[real_path]['count']:
        results[real_path]['count'] = valid_count
    if latest_mod > results[real_path]['last_mod']:
        results[real_path]['last_mod'] = latest_mod

import subprocess

# Get total disk usage of ~/.claude/projects/
try:
    total_size = 0
    for root, dirs, files in os.walk(projects_dir):
        for f in files:
            total_size += os.path.getsize(os.path.join(root, f))
    size_str = f'{total_size / (1024*1024):.1f} MB' if total_size > 1024*1024 else f'{total_size // 1024} KB'
except: size_str = '?'

total_sessions = sum(info['count'] for info in results.values())
print(f'  {DG}{D}~/.claude  {DG}\u2502{D}  {total_sessions} sessions  {DG}\u2502{D}  {size_str}{R}  |  __INFO__')
print()

for path, info in sorted(results.items(), key=lambda x: x[1]['last_mod'], reverse=True):
    rel = relative_time(info['last_mod'])
    name = os.path.basename(path)
    count = info['count']
    s = 's' if count != 1 else ' '
    bar = '█' * min(count, 12)

    # Get current git branch
    branch = ''
    try:
        result = subprocess.run(['git', '-C', path, 'branch', '--show-current'],
                              capture_output=True, text=True, timeout=2)
        if result.returncode == 0 and result.stdout.strip():
            branch = result.stdout.strip()[:15]
    except: pass

    branch_str = f'{MG}{branch}{R}  ' if branch else ''
    print(f'  {CY}{B}{name:<25s}{R}  {branch_str}{DG}{rel:>9s}{R}  {GN}{D}{bar:<12s}{R} {DG}{count} session{s}{R}  |  {path}')
")

if [ -z "$dir_list" ]; then
  echo "No Claude Code sessions found."
  echo "Start using Claude Code and your sessions will appear here."
  exit 0
fi

selected_dir=$(echo "$dir_list" | fzf \
  --header=$'  \033[38;5;176m\033[1mclaude-picker\033[0m\n' \
  --header-first \
  --delimiter="|" \
  --with-nth=1 \
  --layout=reverse \
  --height=50% \
  --border=rounded \
  --margin=1,3 \
  --padding=1,1 \
  --prompt="  project > " \
  --pointer=" ▸" \
  --color="fg:249,fg+:117,bg+:-1,hl:222,hl+:222,pointer:176,prompt:117,header:176,border:238,gutter:-1" \
  --no-separator \
  --preview-window=hidden \
  --ansi)

if [ -z "$selected_dir" ]; then
  exit 0
fi

selected_path=$(echo "$selected_dir" | awk -F'|' '{print $NF}' | xargs)
cd "$selected_path" || exit 1

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Step 2: Pick a session
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

encoded_path=$(echo "$PWD" | sed 's|[/_]|-|g')
export PROJECT_DIR="$HOME/.claude/projects/${encoded_path}"
export SESSIONS_META_DIR="$HOME/.claude/sessions"

session_list=$(PROJECT_DIR="$PROJECT_DIR" SESSIONS_META_DIR="$SESSIONS_META_DIR" bash "$SCRIPT_DIR/lib/session-list.sh")

if [ -z "$session_list" ]; then
  echo "No sessions found. Starting a new one..."
  claude $CLAUDE_FLAGS
  exit 0
fi

proj_name=$(basename "$PWD")

selected=$(echo "$session_list" | fzf \
  --header=$"  \033[38;5;176m\033[1m$proj_name\033[0m  \033[38;5;242m│  enter open  │  ctrl-b bookmark  │  ctrl-e export  │  ctrl-d delete  │  ctrl-c back\033[0m\n" \
  --header-first \
  --delimiter="|" \
  --with-nth=1 \
  --layout=reverse \
  --height=85% \
  --border=rounded \
  --margin=1,3 \
  --padding=1,1 \
  --prompt="  session > " \
  --pointer=" ▸" \
  --color="fg:249,fg+:114,bg+:-1,hl:222,hl+:222,pointer:176,prompt:117,header:176,border:238,gutter:-1" \
  --no-separator \
  --preview="PROJECT_DIR='$PROJECT_DIR' python3 '$SCRIPT_DIR/lib/session-preview.py' \$(echo {} | awk -F'|' '{print \$NF}' | xargs)" \
  --preview-window=right,45%,wrap,border-left \
  --bind="ctrl-b:execute-silent(sid=\$(echo {} | awk -F'|' '{print \$NF}' | xargs) && [ \"\$sid\" != '__NEW__' ] && [ \"\$sid\" != '__HDR1__' ] && [ \"\$sid\" != '__HDR2__' ] && [ \"\$sid\" != '__INFO__' ] && python3 '$SCRIPT_DIR/lib/session-bookmarks.py' \"\$sid\")+reload(PROJECT_DIR='$PROJECT_DIR' SESSIONS_META_DIR='$SESSIONS_META_DIR' bash '$SCRIPT_DIR/lib/session-list.sh')" \
  --bind="ctrl-e:execute(sid=\$(echo {} | awk -F'|' '{print \$NF}' | xargs) && [ \"\$sid\" != '__NEW__' ] && [ \"\$sid\" != '__HDR1__' ] && [ \"\$sid\" != '__HDR2__' ] && [ \"\$sid\" != '__INFO__' ] && path=\$(python3 '$SCRIPT_DIR/lib/session-export.py' \"\$sid\") && echo \"Exported to: \$path\")" \
  --bind="ctrl-d:execute-silent(sid=\$(echo {} | awk -F'|' '{print \$NF}' | xargs) && [ \"\$sid\" != '__NEW__' ] && [ \"\$sid\" != '__HDR1__' ] && [ \"\$sid\" != '__HDR2__' ] && [ \"\$sid\" != '__INFO__' ] && rm -f \"$PROJECT_DIR/\$sid.jsonl\")+reload(PROJECT_DIR='$PROJECT_DIR' SESSIONS_META_DIR='$SESSIONS_META_DIR' bash '$SCRIPT_DIR/lib/session-list.sh')" \
  --ansi)

if [ -n "$selected" ]; then
  session_id=$(echo "$selected" | awk -F'|' '{print $NF}' | xargs)
  case "$session_id" in
    __NEW__)
      if [ "$PIPE_MODE" = "1" ]; then
        echo "__NEW__"
      else
        claude $CLAUDE_FLAGS
      fi
      ;;
    __HDR1__|__HDR2__) exit 0 ;;
    *)
      if [ "$PIPE_MODE" = "1" ]; then
        echo "$session_id"
      else
        claude $CLAUDE_FLAGS --resume "$session_id"
      fi
      ;;
  esac
fi
